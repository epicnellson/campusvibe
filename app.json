{
  "expo": {
    "name": "CampusVibe",
    "slug": "campusvibe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "campusvibe",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.epicnellson.campusvibe",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "CampusVibe needs camera access to take profile photos and listing images.",
        "NSPhotoLibraryUsageDescription": "CampusVibe needs photo library access to upload profile pictures and listing images.",
        "NSUserNotificationsUsageDescription": "CampusVibe sends notifications when someone likes your post, sends you a message, or when new campus events are posted."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.epicnellson.campusvibe",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_CALL_LOG",
        "android.permission.SEND_SMS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": {
            "scheme": "campusvibe",
            "host": "*"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 128,
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CampusVibe needs access to your photos to set your profile picture and upload listing images.",
          "cameraPermission": "CampusVibe needs camera access to take profile photos and listing images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#208AEF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://kvpqkcfevmmlsbxjbgyd.supabase.co",
      "supabaseAnonKey": "sb_publishable_RjFVgowfCzJlECpdoQfWEQ_z01crUVQ",
      "eas": {
        "projectId": "2baa0beb-2ea8-497a-baf9-dbfca36a0cc3"
      },
      "router": {}
    },
    "owner": "epicnellson"
  }
}
